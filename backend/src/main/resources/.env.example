# Server
PORT=8080

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Model Server - Set MODEL_SERVER_MOCK=true in dev to skip needing the actual AI model running
MODEL_SERVER_URL=http://localhost:8000
MODEL_API_KEY=
MODEL_TIMEOUT_MS=30000
MODEL_SERVER_MOCK=true

# Supabase JWT - Must match your Supabase project settings
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Logging - Use DEBUG locally, INFO in production
LOG_LEVEL=INFO